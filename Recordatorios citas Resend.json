        "method": "PATCH",
        "url": "=https://dovoggkeoguqtscmsjna.supabase.co/rest/v1/citas?id=eq.{{ $('Preparar email recordatorio').item.json.cita_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
