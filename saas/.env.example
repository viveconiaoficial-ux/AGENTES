# ── Supabase ─────────────────────────────────────────────────────────────────
# Solo la URL raíz del proyecto (Project URL), sin /rest/v1 ni rutas extras.
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Chat → n8n (proxy /api/chat sin CORS) ───────────────────────────────────
# URL del webhook WEB en n8n (path agente-web). Pon al menos UNA de las dos:
N8N_CHAT_WEBHOOK_URL=https://TU-N8N/webhook/agente-web
# o, si ya la usabas antes en Vercel, sirve igual como destino del proxy:
# NEXT_PUBLIC_CHAT_ENDPOINT=https://TU-N8N/webhook/agente-web

# URL publica de tu SaaS (para generar links/snippets en configuracion).
# Opcional en Vercel: si no la pones, se usa automaticamente VERCEL_URL en produccion.
NEXT_PUBLIC_APP_URL=https://TU-DOMINIO.vercel.app
