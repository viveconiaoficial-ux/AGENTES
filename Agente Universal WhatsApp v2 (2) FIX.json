    {
      "parameters": {
        "jsCode": "const contexto = $('Preparar contexto').item.json;\nconst historialRaw = $input.first().json;\n\n// Historial como array (Supabase devuelve array directamente)\nconst historial = Array.isArray(historialRaw) ? historialRaw : [];\n\n// Construir mensajes para OpenRouter\nconst systemPrompt = `${contexto.prompt_personalizado}\n\nInformación del negocio:\nNombre: ${contexto.negocio_nombre}\nDescripción: ${contexto.negocio_descripcion}\nHorario: ${contexto.negocio_horario}\nDirección: ${contexto.negocio_direccion}\n\nCliente: ${contexto.push_name}`;\n\n// Historial en orden cronológico (viene desc, invertimos)\nconst mensajesHistorial = historial\n  .reverse()\n  .flatMap(h => {\n    const msgs = [];\n    if (h.mensaje) msgs.push({ role: 'user', content: h.mensaje });\n    if (h.respuesta) msgs.push({ role: 'assistant', content: h.respuesta });\n    return msgs;\n  });\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...mensajesHistorial,\n  { role: 'user', content: contexto.mensaje }\n];\n\nreturn [{\n  json: {\n    messages,\n    negocio_id: contexto.negocio_id,\n    telefono_cliente: contexto.telefono_cliente,\n    remote_jid: contexto.remote_jid,\n    mensaje: contexto.mensaje,\n    evolution_host: contexto.evolution_host,\n    evolution_apikey: contexto.evolution_apikey,\n    evolution_instance: contexto.evolution_instance\n  }\n}];"
      },
