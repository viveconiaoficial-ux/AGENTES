    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst data = body?.data || {};\nconst key = data?.key || {};\nconst fromMe = key?.fromMe || false;\n\n// Soporta texto, captions de imagen/video, etc.\nconst message =\n  data?.message?.conversation ||\n  data?.message?.extendedTextMessage?.text ||\n  data?.message?.imageMessage?.caption ||\n  data?.message?.videoMessage?.caption ||\n  data?.message?.buttonsResponseMessage?.selectedDisplayText ||\n  data?.message?.listResponseMessage?.title ||\n  '';\n\n// Posibles candidatos al JID/teléfono real del remitente (soporta @lid en Evolution v2.2+)\nconst candidates = [\n  key?.senderPn,\n  key?.remoteJidAlt,\n  key?.remoteJid,\n  data?.participant\n].filter(Boolean).map(String);\n\nconst preferido = candidates.find(c => c.includes('@s.whatsapp.net'));\nconst remoteJid = preferido || candidates[0] || '';\nconst from = remoteJid.split('@')[0].replace(/\\D/g, '');\n\nconst instance = body?.instance || '';\nconst pushName = data?.pushName || 'Cliente';\nconst event = String(body?.event || '').toLowerCase().replace(/_/g, '.');\n\n// Acepta messages.upsert en cualquier capitalización; ignora si no hay texto o es propio\nif (fromMe || !message || !remoteJid || !event.includes('messages.upsert')) {\n  return [];\n}\n\nreturn [{ json: { message, from, remoteJid, instance, pushName } }];"
      },
